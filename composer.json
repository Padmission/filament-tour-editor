{
    "name": "padmission/filament-tour-editor",
    "description": "Visual tour builder and database-driven tour management for Filament, powered by jibaymcs/filament-tour.",
    "keywords": [
        "filament",
        "tour",
        "editor",
        "builder",
        "driverjs",
        "onboarding"
    ],
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "filament/filament": "^5.0",
        "jibaymcs/filament-tour": "^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "autoload": {
        "psr-4": {
            "Padmission\\FilamentTourEditor\\": "src/",
            "Padmission\\FilamentTourEditor\\Database\\Factories\\": "database/factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Padmission\\FilamentTourEditor\\FilamentTourEditorServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
